# ──────────────────────────────────────────────
#  SpamGuard Engine - .gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production

# Logs
logs/
*.log
npm-debug.log*

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/

# Uploads (runtime user data)
uploads/*
!uploads/.gitkeep

# Test artifacts
*.test.js
test-*.js
*-test.js
*-bulk.json
results.csv

# Coverage
coverage/

# Temp files
tmp/
temp/
*.tmp